# Copy this file to .env and fill in real values (.env is gitignored, this
# file with placeholders isn't). See README.md "1. Credentials" for how to
# get each one.

# --- Jira (your own token) ---
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=
# Optional:
# JIRA_SPRINT_FIELD=customfield_10020
# JIRA_STORY_POINTS_FIELD=customfield_10016
# JIRA_DEFAULT_LOOKBACK_DAYS=90

# --- GitHub (your own token) ---
GITHUB_TOKEN=
GITHUB_ORG=your-org-or-username
# Optional:
# GITHUB_REPOS=repo-one,repo-two

# --- Slack (shared app token) ---
SLACK_BOT_TOKEN=xoxb-...
# Optional:
# SLACK_USER_TOKEN=xoxp-...
# SLACK_DEFAULT_LOOKBACK_DAYS=14

# --- Gmail + Calendar (Google OAuth) ---
# No token here — place client_secret.json in the repo root, then run:
#   uv run python scripts/google_auth_setup.py
# Only needed if you saved those files somewhere else:
# GOOGLE_CLIENT_SECRETS_FILE=client_secret.json
# GOOGLE_TOKEN_FILE=token.json
# GMAIL_MAX_THREADS=50

# --- Your profile (get_user_profile()) ---
USER_NAME=Jane Doe
USER_EMAIL=jane@example.com
USER_TEAM=Platform
USER_ROLE=Backend Engineer
USER_TIMEZONE=Asia/Kolkata
USER_WORKING_HOURS=09:30-18:30

# --- Write actions ---
# Off by default. Set to true to enable the draft/confirm write tools.
WRITES_ENABLED=false
